        {
          "name": "Create List",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();\r",
                  "const expectedName = pm.environment.get(\"list_name\");\r",
                  "\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Check list name\", function () {\r",
                  "    pm.expect(body.name).to.eql(expectedName);\r",
                  "});\r",
                  "\r",
                  "pm.collectionVariables.set(\"list_id\", body.id)\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const listName = \"test_list_\" + Date.now();\r",
                  "pm.environment.set(\"list_name\", listName);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "{{auth_api_key}}"
              },
              {
                "key": "accept",
